# Virtual environment - machine-specific, never commit
venv/
.venv/
env/
ENV/

# Secrets and credentials - NEVER commit these
.env
*.key
*.pem

# Python cache files - auto-generated, not useful to teammates
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Jupyter notebook checkpoints - auto-saved drafts, not needed in repo
.ipynb_checkpoints/

# macOS system files - irrelevant to teammates on other systems
.DS_Store

# Data and large output files - regenerable from scripts
# We keep the .gitkeep files to maintain directory structures in git
data/raw/*
!data/raw/.gitkeep
!data/raw/quality_test.csv
!data/raw/untyped_data.csv
data/processed/*
!data/processed/.gitkeep
!data/processed/cleaned_data.csv
!data/processed/typed_data.csv
!data/processed/deduplicated_data.csv
output/*
!output/.gitkeep
!output/profile_report.json
!output/imputation_decisions.json
!output/dtype_conversion_report.csv
!output/removed_duplicates_audit.csv
!output/dedup_summary.json
!output/dedup_audit_summary.json

# Distribution and build artifacts
*.egg-info/
dist/
build/
