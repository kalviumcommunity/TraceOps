# Virtual environment - machine-specific, never commit
venv/
.venv/
env/
ENV/

# Secrets and credentials - NEVER commit these
.env
*.key
*.pem

# Python cache files - auto-generated, not useful to teammates
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Jupyter notebook checkpoints - auto-saved drafts, not needed in repo
.ipynb_checkpoints/

# macOS system files - irrelevant to teammates on other systems
.DS_Store

# Data and large output files - regenerable from scripts
# We keep the .gitkeep files to maintain directory structures in git
data/raw/*
!data/raw/.gitkeep
!data/raw/quality_test.csv
!data/raw/untyped_data.csv
!data/raw/datetime_transactions.csv
data/processed/*
!data/processed/.gitkeep
!data/processed/cleaned_data.csv
!data/processed/typed_data.csv
!data/processed/deduplicated_data.csv
!data/processed/datetime_features.csv
output/*
!output/.gitkeep
!output/profile_report.json
!output/imputation_decisions.json
!output/dtype_conversion_report.csv
!output/removed_duplicates_audit.csv
!output/dedup_summary.json
!output/dedup_audit_summary.json
!output/hourly_distribution.png
!output/hour_day_heatmap.png
!output/cleaning_log.csv
!data/raw/outliers_data.csv
!data/processed/outliers_handled.csv
!data/raw/validation_data.csv
!data/processed/validated_data.csv
!output/validation_failures.csv
!output/validation_report.json
!data/raw/customers_large.csv
!data/raw/orders_large.csv
!data/processed/merged_orders.csv
!output/unmatched_customers.csv
!output/unmatched_orders.csv
!output/join_validation_report.json
!data/raw/churn_correlation_data.csv
!output/correlation_heatmap.png
!data/raw/customer_segment_data.csv
!output/segment_insights.csv
!output/rolling_avg.png
!output/cumulative.png
!output/trend_analysis.txt
!output/segment_heatmap.png
!output/segmentation_summary.txt

# Distribution and build artifacts
*.egg-info/
dist/
build/
